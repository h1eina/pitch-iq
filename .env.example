# PRIMARY: API-Football (api-sports.io) — 100 req/day, real-time live scores
# Sign up free: https://www.api-football.com (no credit card)
API_FOOTBALL_KEY=your_api_football_key_here

# SECONDARY: Football-Data.org — 10 req/min, NO daily cap
# Sign up free: https://www.football-data.org/client/register
# Used for standings, fixtures, scorers to save API-Football quota for live data
FOOTBALL_DATA_ORG_KEY=your_football_data_org_key_here
